var SPREADSHEET_ID = "1O0R9dAvwDsvyrROLYqpUWX7SzBY8Gr1RTA0BM8Q-WIA";
var ORDERS_SHEET_NAME = "Orders";
var PRODUCT_LIST_SHEET_NAME = "ProductList";
var DRIVE_FOLDER_ID = '1z4_63gXXx5QMSHytr3MI7Kd-VXl5v2LZ';
var BRANCH_ID = '23518';
var API_KEY = 'SLIPOKRRIINSS';

function doPost(e) {
    try {
        var data = JSON.parse(e.postData.contents);
        var productsname = data.productsname;
        var enteredPrice = parseFloat(data.price);
        var buyname = data.buyname;
        var buyemail = data.buyemail;
        var base64 = data.base64;
        var type = data.type;
        var name = data.name;

        // Decode base64 data and create Blob
        var decodedData = Utilities.base64Decode(base64);
        var blob = Utilities.newBlob(decodedData, type, name);

        // Save the file in Google Drive
        var folder = DriveApp.getFolderById(DRIVE_FOLDER_ID);
        var newFile = folder.createFile(blob);
        var fileLink = newFile.getUrl();

        // Verify file with SlipOK API and check price
        var verificationResult = verifySlipWithSlipOK(blob, enteredPrice);

        // Log the result in Google Sheet
        logResultToSheet(productsname, enteredPrice, buyname, buyemail, fileLink, verificationResult);

        // If payment is correct, check price in ProductList and send email if they match
        if (verificationResult === "การชำระเงินถูกต้อง") {
            var productDetails = getProductDetails(productsname);
            if (productDetails && productDetails.price === enteredPrice) {
                sendEmailWithProductDetails(buyemail, productDetails);
                return ContentService.createTextOutput("การชำระเงินถูกต้องและข้อมูลผลิตภัณฑ์ถูกส่งไปยังอีเมล: " + buyemail);
            } else {
                return ContentService.createTextOutput("การชำระเงินถูกต้องแต่ราคาที่กรอกไม่ตรงกับราคาที่บันทึกใน ProductList");
            }
        }

        // Return verification result
        return ContentService.createTextOutput("ผลการตรวจสอบ: " + verificationResult);
    } catch (error) {
        // Return error message
        return ContentService.createTextOutput("ข้อผิดพลาด: " + error.toString());
    }
}

function verifySlipWithSlipOK(blob, expectedPrice) {
    var url = 'https://api.slipok.com/api/line/apikey/' + BRANCH_ID;
    var formData = {
        'files': blob,
        'log': 'true'
    };
    var options = {
        'method': 'post',
        'headers': {
            'x-authorization': API_KEY
        },
        'payload': formData,
        'muteHttpExceptions': true
    };

    try {
        var response = UrlFetchApp.fetch(url, options);
        var jsonResponse = JSON.parse(response.getContentText());

        if (response.getResponseCode() === 200 && jsonResponse.success === true) {
            var actualPrice = parseFloat(jsonResponse.data.amount);
            if (actualPrice === expectedPrice) {
                return "การชำระเงินถูกต้อง"; // Payment is correct
            } else {
                return "ราคาที่ตรวจสอบได้ (" + actualPrice + ") ไม่ตรงกับราคาที่กรอก (" + expectedPrice + ")"; // Price mismatch
            }
        } else if (jsonResponse.code === 1014 && jsonResponse.message === "บัญชีผู้รับไม่ตรงกับบัญชีหลักของร้าน") {
            return "บัญชีผู้รับไม่ตรงกับบัญชีหลักของร้าน"; // Account does not match the store's main account
        } else {
            return "ข้อผิดพลาด: " + (jsonResponse.message || 'ข้อผิดพลาดที่ไม่ทราบสาเหตุ');
        }
    } catch (e) {
        return 'ข้อผิดพลาด: ' + e.message;
    }
}

function logResultToSheet(productsname, price, buyname, buyemail, fileLink, verificationResult) {
    var sheet = getSheetById(SPREADSHEET_ID, ORDERS_SHEET_NAME);
    var timestamp = new Date(); // สร้าง timestamp ปัจจุบัน
    sheet.appendRow([productsname, price, buyname, buyemail, fileLink, verificationResult, timestamp]);
}

function getProductDetails(productsname) {
    var sheet = getSheetById(SPREADSHEET_ID, PRODUCT_LIST_SHEET_NAME);
    var data = sheet.getDataRange().getValues();

    for (var i = 1; i < data.length; i++) { // Skip header row
        if (data[i][0] === productsname) {
            return {
                name: data[i][0],
                description: data[i][1],
                price: parseFloat(data[i][2]),
                file1: data[i][3],
                file2: data[i][4],
            };
        }
    }
    return null;
}

