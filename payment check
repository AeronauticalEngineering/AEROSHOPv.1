function getSheetById(spreadsheetId, sheetName) {
    var spreadsheet = SpreadsheetApp.openById(spreadsheetId);
    var sheet = spreadsheet.getSheetByName(sheetName);

    if (!sheet) {
        return spreadsheet.insertSheet(sheetName);
    }

    return sheet;
}
